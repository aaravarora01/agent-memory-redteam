__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.env
.DS_Store
.idea/
.vscode/
.ipynb_checkpoints/

# Loose training/eval artifacts that land in the repo root (the curated copies
# live under modal_results/). Keep the root clean.
/trainer_state.json
/*_train_metrics.jsonl
/*_eval.jsonl
/*_eval_summary.json

# Generated artifacts (regenerable from scripts/runs).
results/*.png
results/*.csv
results/*.jsonl
results/*.log

# GRPO training run outputs (checkpoints + train_metrics.jsonl). On Modal these
# live on the pismith-outputs Volume; a local run writes them here.
outputs/

# Milestone-figure exceptions: pin these so teammates / the report can
# reference a specific git revision without rerunning the sweep.
!results/exp3_curve.png

# Local embedded cache of the benign corpus. The committed seed
# (data/benign_memories.seed.jsonl) is text-only; running
# data/build_benign_corpus.py materializes the embedded version below
# for faster MemoryStore loads.
data/benign_memories.jsonl

# Finance poisoning simulator generated logs
finance_poisoning/results/*.jsonl
finance_poisoning/results/*.png
finance_poisoning/results/*.log
!finance_poisoning/results/.gitkeep

# Internal reference notes from the team's sibling IPI codebase
# (not this project's code; not for redistribution).
other-codebase.txt

# Internal milestone plan — not published with the repo.
plan.md
